# Copy this file to .env and fill in the values before running docker compose.

# JWT secret for authentication — generate with: openssl rand -base64 32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# PostgreSQL credentials
POSTGRES_DB=photomanager
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

# Absolute path on the host to the directory containing images to catalogue.
# This directory is mounted read-write into the backend container so all
# write features (delete duplicates, convert, sync, move, copy) work on
# your actual files.
# Example (Linux/macOS): HOST_IMAGE_DIR=/home/yourname/Pictures
# Example (Windows):     HOST_IMAGE_DIR=C:/Users/yourname/Pictures
HOST_IMAGE_DIR=/path/to/your/pictures

# Linux note: if write operations fail with permission errors, add the
# following to docker-compose.yml under the 'backend' service:
#   user: "${UID}:${GID}"
# Then run: UID=$(id -u) GID=$(id -g) docker compose up
