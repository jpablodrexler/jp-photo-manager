{
  "annotations": { "list": [] },
  "description": "JP Photo Manager — Spring Boot metrics",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (uri, method, status) (rate(http_server_requests_seconds_count{job=\"photomanager-backend\"}[1m]))",
          "legendFormat": "{{method}} {{uri}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP p95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"photomanager-backend\"}[5m])))",
          "legendFormat": "p95 {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "HTTP p99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"photomanager-backend\"}[5m])))",
          "legendFormat": "p99 {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"photomanager-backend\", area=\"heap\"}",
          "legendFormat": "used ({{id}})",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"photomanager-backend\", area=\"heap\"}",
          "legendFormat": "max ({{id}})",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"photomanager-backend\"}",
          "legendFormat": "process CPU",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{job=\"photomanager-backend\"}",
          "legendFormat": "system CPU",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"photomanager-backend\"}",
          "legendFormat": "live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=\"photomanager-backend\"}",
          "legendFormat": "daemon",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Catalog Job Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "spring_batch_job_seconds_sum{job=\"photomanager-backend\", name=\"catalogJob\"} / spring_batch_job_seconds_count{job=\"photomanager-backend\", name=\"catalogJob\"}",
          "legendFormat": "avg duration",
          "refId": "A"
        },
        {
          "expr": "increase(spring_batch_job_seconds_count{job=\"photomanager-backend\", name=\"catalogJob\", status=\"COMPLETED\"}[1h])",
          "legendFormat": "completed runs / hour",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["photomanager"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "JP Photo Manager",
  "uid": "photomanager-main",
  "version": 1
}
