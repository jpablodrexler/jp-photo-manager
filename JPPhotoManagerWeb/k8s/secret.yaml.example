# Template for the secret values required by the stack — mirrors
# ../.env.example. Copy this file to secret.yaml (already git-ignored, see
# ../../.gitignore) and replace every "change-me" placeholder before
# applying, exactly like the docker-compose `.env` workflow:
#
#   cp secret.yaml.example secret.yaml
#   # edit secret.yaml with real values
#   kubectl apply -f secret.yaml
#
# Generate JWT_SECRET and GRAFANA_ADMIN_PASSWORD with:
#   openssl rand -base64 32
#
# For a shared or production cluster, do not keep secrets in a plain
# manifest at all — use `kubectl create secret generic` imperatively, a
# kustomize secretGenerator with an env file kept out of git, or a secret
# manager (Sealed Secrets, External Secrets Operator, Vault, etc.).
apiVersion: v1
kind: Secret
metadata:
  name: photomanager-secrets
  namespace: photomanager
type: Opaque
stringData:
  POSTGRES_PASSWORD: "change-me"
  JWT_SECRET: "change-me-generate-with-openssl-rand-base64-32"
  GRAFANA_ADMIN_PASSWORD: "change-me"
