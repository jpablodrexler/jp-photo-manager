#!/usr/bin/env node
'use strict';

const { execSync, spawnSync } = require('child_process');
const path = require('path');

const repoRoot = execSync('git rev-parse --show-toplevel').toString().trim();
const changedFiles = execSync('git diff --cached --name-only').toString().trim().split('\n').filter(Boolean);

const runBackend  = changedFiles.some(f => f.startsWith('JPPhotoManagerWeb/backend/'));
const runFrontend = changedFiles.some(f => f.startsWith('JPPhotoManagerWeb/frontend/'));

if (!runBackend && !runFrontend) process.exit(0);

function run(label, cmd, args, cwd) {
  console.log(`>>> ${label} — running ${cmd} ${args.join(' ')}`);
  const result = spawnSync(cmd, args, { cwd, stdio: 'inherit', shell: true });
  if (result.status !== 0) {
    console.error(`\n✗ ${label} failed. Commit blocked.`);
    console.error('  Fix the failures above, then re-stage and retry.');
    process.exit(1);
  }
  console.log(`✓ ${label} passed`);
}

if (runBackend) {
  run('Backend tests', 'mvn', ['test', '-q'], path.join(repoRoot, 'JPPhotoManagerWeb/backend'));
}

if (runFrontend) {
  run('Frontend tests', 'npm', ['test', '--silent'], path.join(repoRoot, 'JPPhotoManagerWeb/frontend'));
}
